<Window x:Class="WasfatyInvoiceProcessor.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:materialDesign="http://materialdesigninxaml.net/winfx/xaml/themes"
        TextElement.Foreground="{DynamicResource MaterialDesignBody}"
        Background="{StaticResource ModernBackground}"
        FontFamily="{materialDesign:MaterialDesignFont}"
        Title="Wasfaty Invoice Processor" 
        Height="850" 
        Width="1400"
        MinHeight="700"
        MinWidth="1100"
        WindowStartupLocation="CenterScreen"
        WindowState="Maximized">

    <Window.Resources>
        <BooleanToVisibilityConverter x:Key="BoolToVis"/>
        
        <!-- Modern Styles -->
        <Style TargetType="TextBlock" x:Key="HeaderTextStyle">
            <Setter Property="FontSize" Value="20"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="Foreground" Value="{StaticResource ModernBlue}"/>
            <Setter Property="Margin" Value="0,0,0,16"/>
        </Style>
        
        <Style TargetType="TextBlock" x:Key="SubHeaderTextStyle">
            <Setter Property="FontSize" Value="14"/>
            <Setter Property="FontWeight" Value="Medium"/>
            <Setter Property="Foreground" Value="{StaticResource ModernText}"/>
            <Setter Property="Margin" Value="0,0,0,8"/>
        </Style>
        
        <Style TargetType="TextBlock" x:Key="LabelTextStyle">
            <Setter Property="FontSize" Value="12"/>
            <Setter Property="FontWeight" Value="Medium"/>
            <Setter Property="Foreground" Value="{StaticResource ModernTextSecondary}"/>
            <Setter Property="Margin" Value="0,12,0,6"/>
        </Style>
        
        <Style TargetType="Button" x:Key="ModernPrimaryButton" BasedOn="{StaticResource MaterialDesignRaisedButton}">
            <Setter Property="Height" Value="40"/>
            <Setter Property="FontSize" Value="13"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="materialDesign:ElevationAssist.Elevation" Value="Dp2"/>
            <Setter Property="Cursor" Value="Hand"/>
        </Style>
        
        <Style TargetType="Button" x:Key="ModernSecondaryButton" BasedOn="{StaticResource MaterialDesignOutlinedButton}">
            <Setter Property="Height" Value="40"/>
            <Setter Property="FontSize" Value="13"/>
            <Setter Property="FontWeight" Value="Medium"/>
            <Setter Property="Cursor" Value="Hand"/>
        </Style>
        
        <Style TargetType="materialDesign:Card" x:Key="ModernCard">
            <Setter Property="materialDesign:ElevationAssist.Elevation" Value="Dp4"/>
            <Setter Property="Background" Value="{StaticResource ModernCard}"/>
            <Setter Property="Padding" Value="20"/>
        </Style>
        
        <Style TargetType="Separator" x:Key="ModernSeparator">
            <Setter Property="Margin" Value="0,20,0,20"/>
            <Setter Property="Background" Value="{StaticResource ModernBorder}"/>
        </Style>
    </Window.Resources>

    <Grid>
        <!-- Modern Gradient Header -->
        <Border VerticalAlignment="Top" Height="90">
            <Border.Background>
                <LinearGradientBrush StartPoint="0,0" EndPoint="1,0">
                    <GradientStop Color="#1E88E5" Offset="0"/>
                    <GradientStop Color="#00ACC1" Offset="1"/>
                </LinearGradientBrush>
            </Border.Background>
            <Border.Effect>
                <DropShadowEffect Color="#000000" Opacity="0.15" BlurRadius="12" ShadowDepth="4" Direction="270"/>
            </Border.Effect>
            
            <Grid Margin="24,0">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>
                
                <!-- App Title Section -->
                <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                    <Border Background="#FFFFFF" 
                            CornerRadius="10" 
                            Width="48" 
                            Height="48" 
                            Padding="8">
                        <materialDesign:PackIcon Kind="FileDocumentMultiple" 
                                                 Width="28" 
                                                 Height="28" 
                                                 Foreground="{StaticResource ModernBlue}"
                                                 VerticalAlignment="Center"
                                                 HorizontalAlignment="Center"/>
                    </Border>
                    <StackPanel VerticalAlignment="Center" Margin="12,0,0,0">
                        <TextBlock Text="Wasfaty Invoice Processor"
                                   FontSize="20" 
                                   FontWeight="Bold"
                                   Foreground="White"/>
                        <StackPanel Orientation="Horizontal">
                            <TextBlock Text="Automated invoice processing and tracking system"
                                       FontSize="12" 
                                       Foreground="White"
                                       Opacity="0.9"
                                       Margin="0,2,0,0"/>
                            <TextBlock Text="{Binding AppVersion}"
                                       FontSize="11"
                                       Foreground="White"
                                       Opacity="0.7"
                                       Margin="8,2,0,0"
                                       VerticalAlignment="Center"/>
                        </StackPanel>
                    </StackPanel>
                </StackPanel>
                
                <!-- Connection Status Badge -->
                <Border Grid.Column="2" 
                        Background="#FFFFFF" 
                        CornerRadius="20" 
                        Padding="20,12"
                        VerticalAlignment="Center">
                    <Border.Effect>
                        <DropShadowEffect Color="#000000" Opacity="0.1" BlurRadius="8" ShadowDepth="2"/>
                    </Border.Effect>
                    <StackPanel Orientation="Horizontal">
                        <Ellipse x:Name="ConnectionStatusIcon"
                                 Width="12"
                                 Height="12"
                                 Fill="#E53935"
                                 VerticalAlignment="Center"
                                 Margin="0,0,10,0"/>
                        <TextBlock x:Name="ConnectionStatusText"
                                   Text="Not Connected"
                                   FontSize="13"
                                   FontWeight="SemiBold"
                                   Foreground="{StaticResource ModernText}"
                                   VerticalAlignment="Center"/>
                    </StackPanel>
                </Border>
            </Grid>
        </Border>

        <!-- Main Content Area -->
        <Grid Margin="24,110,24,24">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="350" MinWidth="320" MaxWidth="420"/>
                <ColumnDefinition Width="*"/>
            </Grid.ColumnDefinitions>

            <!-- Left Panel - Control Cards -->
            <ScrollViewer VerticalScrollBarVisibility="Auto">
                <StackPanel>
                    <!-- Single Date Processing Card -->
                    <materialDesign:Card Style="{StaticResource ModernCard}" Margin="0,0,16,16">
                        <StackPanel>
                            <StackPanel Orientation="Horizontal" Margin="0,0,0,16">
                                <Border Background="{StaticResource ModernBlue}"
                                        Width="36"
                                        Height="36"
                                        CornerRadius="8"
                                        Padding="6"
                                        Margin="0,0,10,0">
                                    <materialDesign:PackIcon Kind="CalendarToday" 
                                                             Width="22" 
                                                             Height="22" 
                                                             Foreground="White"/>
                                </Border>
                                <StackPanel VerticalAlignment="Center">
                                    <TextBlock Text="Single Date" Style="{StaticResource HeaderTextStyle}" Margin="0"/>
                                    <TextBlock Text="Process invoices for one day" 
                                               Style="{StaticResource LabelTextStyle}"
                                               Margin="0,2,0,0"/>
                                </StackPanel>
                            </StackPanel>

                            <TextBlock Text="SELECT DATE" Style="{StaticResource LabelTextStyle}"/>
                            <DatePicker x:Name="SingleDatePicker"
                                        materialDesign:HintAssist.Hint="Choose a date"
                                        Style="{StaticResource MaterialDesignOutlinedDatePicker}"
                                        Margin="0,0,0,16"
                                        FontSize="13"/>

                            <Button x:Name="ProcessSingleButton"
                                    Content="PROCESS DATE"
                                    Style="{StaticResource ModernPrimaryButton}"
                                    Click="ProcessSingleButton_Click"
                                    Margin="0,0,0,10"/>

                            <Button x:Name="ReprocessSingleButton"
                                    Content="REPROCESS DATE"
                                    Style="{StaticResource ModernSecondaryButton}"
                                    Click="ReprocessSingleButton_Click"/>
                        </StackPanel>
                    </materialDesign:Card>

                    <!-- Date Range Processing Card -->
                    <materialDesign:Card Style="{StaticResource ModernCard}" Margin="0,0,16,16">
                        <StackPanel>
                            <StackPanel Orientation="Horizontal" Margin="0,0,0,16">
                                <Border Background="{StaticResource ModernTeal}"
                                        Width="36"
                                        Height="36"
                                        CornerRadius="8"
                                        Padding="6"
                                        Margin="0,0,10,0">
                                    <materialDesign:PackIcon Kind="CalendarRange" 
                                                             Width="22" 
                                                             Height="22" 
                                                             Foreground="White"/>
                                </Border>
                                <StackPanel VerticalAlignment="Center">
                                    <TextBlock Text="Date Range" Style="{StaticResource HeaderTextStyle}" Margin="0"/>
                                    <TextBlock Text="Process multiple days in batch" 
                                               Style="{StaticResource LabelTextStyle}"
                                               Margin="0,2,0,0"/>
                                </StackPanel>
                            </StackPanel>

                            <TextBlock Text="START DATE" Style="{StaticResource LabelTextStyle}"/>
                            <DatePicker x:Name="StartDatePicker"
                                        materialDesign:HintAssist.Hint="From date"
                                        Style="{StaticResource MaterialDesignOutlinedDatePicker}"
                                        Margin="0,0,0,12"
                                        FontSize="13"/>

                            <TextBlock Text="END DATE" Style="{StaticResource LabelTextStyle}"/>
                            <DatePicker x:Name="EndDatePicker"
                                        materialDesign:HintAssist.Hint="To date"
                                        Style="{StaticResource MaterialDesignOutlinedDatePicker}"
                                        Margin="0,0,0,16"
                                        FontSize="13"/>

                            <Button x:Name="ProcessRangeButton"
                                    Content="PROCESS RANGE"
                                    Style="{StaticResource ModernPrimaryButton}"
                                    Click="ProcessRangeButton_Click"
                                    Margin="0,0,0,10"/>

                            <Button x:Name="ReprocessRangeButton"
                                    Content="REPROCESS RANGE"
                                    Style="{StaticResource ModernSecondaryButton}"
                                    Click="ReprocessRangeButton_Click"/>
                        </StackPanel>
                    </materialDesign:Card>

                    <!-- Quick Actions Card -->
                    <materialDesign:Card Style="{StaticResource ModernCard}" Margin="0,0,16,0">
                        <StackPanel>
                            <StackPanel Orientation="Horizontal" Margin="0,0,0,16">
                                <Border Background="{StaticResource ModernWarning}"
                                        Width="36"
                                        Height="36"
                                        CornerRadius="8"
                                        Padding="6"
                                        Margin="0,0,10,0">
                                    <materialDesign:PackIcon Kind="FlashAuto" 
                                                             Width="22" 
                                                             Height="22" 
                                                             Foreground="White"/>
                                </Border>
                                <StackPanel VerticalAlignment="Center">
                                    <TextBlock Text="Quick Actions" Style="{StaticResource HeaderTextStyle}" Margin="0"/>
                                    <TextBlock Text="Shortcuts and utilities" 
                                               Style="{StaticResource LabelTextStyle}"
                                               Margin="0,2,0,0"/>
                                </StackPanel>
                            </StackPanel>

                            <Button x:Name="TestConnectionButton"
                                    Style="{StaticResource ModernSecondaryButton}"
                                    Click="TestConnectionButton_Click"
                                    Margin="0,0,0,10">
                                <StackPanel Orientation="Horizontal">
                                    <materialDesign:PackIcon Kind="Connection" 
                                                             Width="18" 
                                                             Height="18" 
                                                             VerticalAlignment="Center"
                                                             Margin="0,0,8,0"/>
                                    <TextBlock Text="TEST CONNECTIONS" VerticalAlignment="Center"/>
                                </StackPanel>
                            </Button>

                            <Button x:Name="RefreshHistoryButton"
                                    Style="{StaticResource ModernSecondaryButton}"
                                    Click="RefreshHistoryButton_Click"
                                    Margin="0,0,0,10">
                                <StackPanel Orientation="Horizontal">
                                    <materialDesign:PackIcon Kind="Refresh" 
                                                             Width="18" 
                                                             Height="18" 
                                                             VerticalAlignment="Center"
                                                             Margin="0,0,8,0"/>
                                    <TextBlock Text="REFRESH HISTORY" VerticalAlignment="Center"/>
                                </StackPanel>
                            </Button>

                            <Button x:Name="GenerateReportButton"
                                    Style="{StaticResource ModernSecondaryButton}"
                                    Click="GenerateReportButton_Click">
                                <StackPanel Orientation="Horizontal">
                                    <materialDesign:PackIcon Kind="FileChart" 
                                                             Width="18" 
                                                             Height="18" 
                                                             VerticalAlignment="Center"
                                                             Margin="0,0,8,0"/>
                                    <TextBlock Text="GENERATE REPORT" VerticalAlignment="Center"/>
                                </StackPanel>
                            </Button>
                        </StackPanel>
                    </materialDesign:Card>
                </StackPanel>
            </ScrollViewer>

            <!-- Right Panel - History and Activity -->
            <Grid Grid.Column="1">
                <Grid.RowDefinitions>
                    <RowDefinition Height="*"/>
                    <RowDefinition Height="240"/>
                </Grid.RowDefinitions>

                <!-- Processing History Card -->
                <materialDesign:Card Style="{StaticResource ModernCard}" Margin="0,0,0,16">
                    <Grid>
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="*"/>
                        </Grid.RowDefinitions>

                        <!-- History Header -->
                        <Grid Margin="0,0,0,16">
                            <StackPanel Orientation="Horizontal">
                                <Border Background="{StaticResource ModernSuccess}"
                                        Width="36"
                                        Height="36"
                                        CornerRadius="8"
                                        Padding="6"
                                        Margin="0,0,10,0">
                                    <materialDesign:PackIcon Kind="History" 
                                                             Width="22" 
                                                             Height="22" 
                                                             Foreground="White"/>
                                </Border>
                                <StackPanel VerticalAlignment="Center">
                                    <TextBlock Text="Processing History" 
                                               Style="{StaticResource HeaderTextStyle}" 
                                               Margin="0"/>
                                    <TextBlock x:Name="HistoryCountText"
                                               FontSize="12"
                                               Foreground="{StaticResource ModernTextSecondary}"
                                               Margin="0,2,0,0"/>
                                </StackPanel>
                            </StackPanel>
                        </Grid>

                        <!-- History DataGrid with modern styling -->
                        <Border Grid.Row="1" 
                                BorderBrush="{StaticResource ModernBorder}" 
                                BorderThickness="1" 
                                CornerRadius="8">
                            <DataGrid x:Name="HistoryDataGrid"
                                      AutoGenerateColumns="False"
                                      CanUserAddRows="False"
                                      IsReadOnly="True"
                                      SelectionMode="Single"
                                      HeadersVisibility="Column"
                                      GridLinesVisibility="None"
                                      AlternationCount="2"
                                      AlternatingRowBackground="#F9FAFB"
                                      FontSize="13"
                                      RowHeight="48"
                                      materialDesign:DataGridAssist.CellPadding="16 12"
                                      materialDesign:DataGridAssist.ColumnHeaderPadding="16 12">
                                <DataGrid.ColumnHeaderStyle>
                                    <Style TargetType="DataGridColumnHeader" BasedOn="{StaticResource MaterialDesignDataGridColumnHeader}">
                                        <Setter Property="FontWeight" Value="SemiBold"/>
                                        <Setter Property="FontSize" Value="12"/>
                                        <Setter Property="Foreground" Value="{StaticResource ModernTextSecondary}"/>
                                        <Setter Property="Background" Value="#F5F7FA"/>
                                    </Style>
                                </DataGrid.ColumnHeaderStyle>
                                <DataGrid.Columns>
                                    <DataGridTextColumn Header="DATE" 
                                                        Binding="{Binding ProcessingDate, StringFormat=yyyy-MM-dd}"
                                                        Width="110">
                                        <DataGridTextColumn.ElementStyle>
                                            <Style TargetType="TextBlock">
                                                <Setter Property="FontWeight" Value="SemiBold"/>
                                                <Setter Property="Foreground" Value="{StaticResource ModernText}"/>
                                            </Style>
                                        </DataGridTextColumn.ElementStyle>
                                    </DataGridTextColumn>
                                    <DataGridTextColumn Header="STATUS" 
                                                        Binding="{Binding Status}"
                                                        Width="100">
                                        <DataGridTextColumn.ElementStyle>
                                            <Style TargetType="TextBlock">
                                                <Setter Property="FontWeight" Value="Medium"/>
                                            </Style>
                                        </DataGridTextColumn.ElementStyle>
                                    </DataGridTextColumn>
                                    <DataGridTextColumn Header="TOTAL" 
                                                        Binding="{Binding TotalInvoices}"
                                                        Width="70"/>
                                    <DataGridTextColumn Header="SUCCESS" 
                                                        Binding="{Binding SuccessCount}"
                                                        Width="80">
                                        <DataGridTextColumn.ElementStyle>
                                            <Style TargetType="TextBlock">
                                                <Setter Property="Foreground" Value="{StaticResource ModernSuccess}"/>
                                                <Setter Property="FontWeight" Value="SemiBold"/>
                                            </Style>
                                        </DataGridTextColumn.ElementStyle>
                                    </DataGridTextColumn>
                                    <DataGridTextColumn Header="SKIPPED" 
                                                        Binding="{Binding SkippedCount}"
                                                        Width="80">
                                        <DataGridTextColumn.ElementStyle>
                                            <Style TargetType="TextBlock">
                                                <Setter Property="Foreground" Value="{StaticResource ModernWarning}"/>
                                                <Setter Property="FontWeight" Value="SemiBold"/>
                                            </Style>
                                        </DataGridTextColumn.ElementStyle>
                                    </DataGridTextColumn>
                                    <DataGridTextColumn Header="FAILED" 
                                                        Binding="{Binding FailedCount}"
                                                        Width="70">
                                        <DataGridTextColumn.ElementStyle>
                                            <Style TargetType="TextBlock">
                                                <Setter Property="Foreground" Value="{StaticResource ModernError}"/>
                                                <Setter Property="FontWeight" Value="SemiBold"/>
                                            </Style>
                                        </DataGridTextColumn.ElementStyle>
                                    </DataGridTextColumn>
                                    <DataGridTextColumn Header="STARTED" 
                                                        Binding="{Binding StartedAt, StringFormat=HH:mm:ss}"
                                                        Width="85"/>
                                    <DataGridTextColumn Header="COMPLETED" 
                                                        Binding="{Binding CompletedAt, StringFormat=HH:mm:ss}"
                                                        Width="95"/>
                                    <DataGridTextColumn Header="MESSAGE" 
                                                        Binding="{Binding ResponseMessage}"
                                                        Width="*">
                                        <DataGridTextColumn.ElementStyle>
                                            <Style TargetType="TextBlock">
                                                <Setter Property="TextTrimming" Value="CharacterEllipsis"/>
                                                <Setter Property="ToolTip" Value="{Binding ResponseMessage}"/>
                                            </Style>
                                        </DataGridTextColumn.ElementStyle>
                                    </DataGridTextColumn>
                                </DataGrid.Columns>
                            </DataGrid>
                        </Border>
                    </Grid>
                </materialDesign:Card>

                <!-- Activity Log Card -->
                <materialDesign:Card Grid.Row="1" Style="{StaticResource ModernCard}">
                    <Grid>
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="*"/>
                        </Grid.RowDefinitions>

                        <!-- Log Header -->
                        <Grid Margin="0,0,0,16">
                            <StackPanel Orientation="Horizontal">
                                <Border Background="{StaticResource ModernBlue}"
                                        Width="36"
                                        Height="36"
                                        CornerRadius="8"
                                        Padding="6"
                                        Margin="0,0,10,0">
                                    <materialDesign:PackIcon Kind="TextBox" 
                                                             Width="22" 
                                                             Height="22" 
                                                             Foreground="White"/>
                                </Border>
                                <TextBlock Text="Activity Log" 
                                           Style="{StaticResource HeaderTextStyle}" 
                                           Margin="0"
                                           VerticalAlignment="Center"/>
                            </StackPanel>
                            <Button x:Name="ClearLogButton"
                                    Style="{StaticResource MaterialDesignFlatButton}"
                                    HorizontalAlignment="Right"
                                    Click="ClearLogButton_Click"
                                    Height="36"
                                    Padding="20,0">
                                <StackPanel Orientation="Horizontal">
                                    <materialDesign:PackIcon Kind="DeleteOutline" 
                                                             Width="18" 
                                                             Height="18" 
                                                             VerticalAlignment="Center"
                                                             Margin="0,0,6,0"/>
                                    <TextBlock Text="CLEAR" VerticalAlignment="Center"/>
                                </StackPanel>
                            </Button>
                        </Grid>

                        <!-- Log Display -->
                        <Border Grid.Row="1" 
                                BorderBrush="{StaticResource ModernBorder}" 
                                BorderThickness="1" 
                                CornerRadius="8"
                                Background="#F9FAFB">
                            <ScrollViewer VerticalScrollBarVisibility="Auto"
                                          HorizontalScrollBarVisibility="Auto"
                                          Padding="16">
                                <TextBox x:Name="LogTextBox"
                                         IsReadOnly="True"
                                         TextWrapping="Wrap"
                                         BorderThickness="0"
                                         FontFamily="Consolas"
                                         FontSize="12"
                                         Background="Transparent"
                                         Foreground="{StaticResource ModernText}"
                                         VerticalAlignment="Stretch"/>
                            </ScrollViewer>
                        </Border>
                    </Grid>
                </materialDesign:Card>
            </Grid>
        </Grid>

        <!-- Progress Overlay (shows during processing) -->
        <Grid x:Name="ProgressOverlay" 
              Background="#80000000" 
              Visibility="Collapsed">
            <Border Background="White" 
                    CornerRadius="12" 
                    Width="400" 
                    Height="180"
                    Padding="32">
                <Border.Effect>
                    <DropShadowEffect Color="#000000" Opacity="0.3" BlurRadius="20" ShadowDepth="0"/>
                </Border.Effect>
                <StackPanel VerticalAlignment="Center">
                    <StackPanel Orientation="Horizontal" Margin="0,0,0,20" HorizontalAlignment="Center">
                        <materialDesign:PackIcon Kind="ProgressClock" 
                                                 Width="32" 
                                                 Height="32" 
                                                 Foreground="{StaticResource ModernBlue}"
                                                 VerticalAlignment="Center"
                                                 Margin="0,0,12,0"/>
                        <TextBlock x:Name="StatusText" 
                                   Text="Processing..."
                                   FontSize="18"
                                   FontWeight="SemiBold"
                                   Foreground="{StaticResource ModernText}"
                                   VerticalAlignment="Center"/>
                    </StackPanel>
                    <ProgressBar x:Name="ProgressBar" 
                                 Height="6"
                                 Minimum="0" 
                                 Maximum="100"
                                 Foreground="{StaticResource ModernBlue}"/>
                    <TextBlock x:Name="ProgressText"
                               Text="0%"
                               FontSize="14"
                               Foreground="{StaticResource ModernTextSecondary}"
                               HorizontalAlignment="Center"
                               Margin="0,12,0,0"/>
                </StackPanel>
            </Border>
        </Grid>
    </Grid>
</Window>
