<Application x:Class="WasfatyInvoiceProcessor.App"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:materialDesign="http://materialdesigninxaml.net/winfx/xaml/themes"
             StartupUri="MainWindow.xaml">
    <Application.Resources>
        <ResourceDictionary>
            <ResourceDictionary.MergedDictionaries>
                <materialDesign:BundledTheme BaseTheme="Light" 
                                            PrimaryColor="Blue" 
                                            SecondaryColor="Teal" />
                <ResourceDictionary Source="pack://application:,,,/MaterialDesignThemes.Wpf;component/Themes/MaterialDesignTheme.Defaults.xaml" />
            </ResourceDictionary.MergedDictionaries>
            
            <!-- Modern Color Palette -->
            <SolidColorBrush x:Key="ModernBlue" Color="#1E88E5"/>
            <SolidColorBrush x:Key="ModernTeal" Color="#00ACC1"/>
            <SolidColorBrush x:Key="ModernSuccess" Color="#43A047"/>
            <SolidColorBrush x:Key="ModernWarning" Color="#FB8C00"/>
            <SolidColorBrush x:Key="ModernError" Color="#E53935"/>
            <SolidColorBrush x:Key="ModernBackground" Color="#F5F7FA"/>
            <SolidColorBrush x:Key="ModernCard" Color="#FFFFFF"/>
            <SolidColorBrush x:Key="ModernBorder" Color="#E1E8ED"/>
            <SolidColorBrush x:Key="ModernText" Color="#263238"/>
            <SolidColorBrush x:Key="ModernTextSecondary" Color="#546E7A"/>
            
            <!-- Gradient Brushes -->
            <LinearGradientBrush x:Key="HeaderGradient" StartPoint="0,0" EndPoint="1,0">
                <GradientStop Color="#1E88E5" Offset="0"/>
                <GradientStop Color="#00ACC1" Offset="1"/>
            </LinearGradientBrush>
            
        </ResourceDictionary>
    </Application.Resources>
</Application>
